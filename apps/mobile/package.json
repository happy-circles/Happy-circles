{
  "name": "@happy-circles/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "node ./scripts/start-expo.mjs",
    "start:clear": "node ./scripts/start-expo.mjs --clear",
    "start:go": "node ./scripts/start-expo.mjs --go",
    "start:go:clear": "node ./scripts/start-expo.mjs --go --clear",
    "start:tunnel": "node ./scripts/start-expo.mjs --go --tunnel",
    "start:tunnel:clear": "node ./scripts/start-expo.mjs --go --tunnel --clear",
    "android": "node ./scripts/start-expo.mjs --android",
    "ios": "node ./scripts/start-expo.mjs --ios",
    "web": "node ./scripts/start-expo.mjs --web",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@happy-circles/application": "workspace:*",
    "@happy-circles/shared": "workspace:*",
    "@supabase/supabase-js": "^2.49.1",
    "@tanstack/react-query": "^5.62.7",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-asset": "~12.0.12",
    "expo-camera": "~17.0.8",
    "expo-clipboard": "~8.0.7",
    "expo-constants": "~18.0.13",
    "expo-contacts": "~15.0.11",
    "expo-dev-client": "~6.0.16",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-qrcode-svg": "^6.3.15",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "babel-preset-expo": "~54.0.10"
  }
}
